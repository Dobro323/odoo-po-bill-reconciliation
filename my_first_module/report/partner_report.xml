<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_partner_priority" model="ir.actions.report">
        <field name="name">Partner Priority Report</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">my_first_module.report_partner_priority</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
    </record>

    <template id="report_partner_priority">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Partner Priority Report</h2>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Priority</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="partner">
                                <tr>
                                    <td><t t-esc="partner.name"/></td>
                                    <td><t t-esc="partner.email"/></td>
                                    <td><t t-esc="partner.customer_priority"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>